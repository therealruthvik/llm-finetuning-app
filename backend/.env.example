# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJh...          # service_role key (Settings → API)
SUPABASE_JWT_SECRET=your-jwt-secret   # Settings → API → JWT Secret

# ── Modal ─────────────────────────────────────────────────────
MODAL_WEBHOOK_URL=https://your-modal-app--training-webhook.modal.run
MODAL_TOKEN_ID=ak-...                 # modal token (modal.com → settings)
MODAL_TOKEN_SECRET=as-...

# ── Internal security ─────────────────────────────────────────
INTERNAL_SECRET=change-me-to-random-secret   # Modal → Backend auth

# ── Frontend URL (CORS) ───────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app

# ── Self URL (Backend) ────────────────────────────────────────
BACKEND_URL=https://your-backend.onrender.com
